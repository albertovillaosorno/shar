temp/
tmp/
logs/
dependencies/

# ==============================================================================
# Unreal Engine
# Compiled state, editor configurations, and derived data.
# Generated solution and project files (*.sln, *.slnx, *.vcxproj, ignored in
# the Visual Studio section below) are machine-generated by UnrealBuildTool
# and embed machine-specific engine-installation routes; every workstation
# regenerates them locally from the tracked .uproject descriptor, so they are
# never tracked and never audited by the route guard.
# ==============================================================================
Binaries/
DerivedDataCache/
Intermediate/
Saved/
**/Binaries/
**/DerivedDataCache/
**/Intermediate/
**/Saved/
Build/*
!Build/*/
Build/*/**
!Build/*/PakBlacklist*.txt
!Build/**/*.ico
*_BuiltData.uasset
Plugins/*/Binaries/*
Plugins/*/Intermediate/*

# Unreal project plugins are installed locally and are never vendored.
src/uproject/Plugins/

# Unreal binary assets (stay local unless deliberately force-added via LFS)
*.uasset
*.umap

