# Text normalization
* text=auto eol=lf

# Windows/project files that should keep CRLF if generated by tools
*.sln text eol=crlf
*.slnx text eol=crlf
*.vcxproj text eol=crlf
*.vcxproj.filters text eol=crlf

# Binary image assets
*.jpg binary

# Canonical authored World Partition map publication
src/uproject/Content/SHAR/Maps/OpenWorld/W_SHAR_OpenWorld.umap filter=lfs diff=lfs merge=lfs -text
src/uproject/Content/SHAR/Maps/OpenWorld/W_SHAR_OpenWorld_HLOD0_Instancing.uasset filter=lfs diff=lfs merge=lfs -text
src/uproject/Content/__ExternalActors__/SHAR/Maps/OpenWorld/W_SHAR_OpenWorld/** filter=lfs diff=lfs merge=lfs -text
src/uproject/Content/__ExternalObjects__/SHAR/Maps/OpenWorld/W_SHAR_OpenWorld/** filter=lfs diff=lfs merge=lfs -text
